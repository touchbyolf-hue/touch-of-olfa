SESSION_SECRET=change-this-secret
FIREBASE_PROJECT_ID=touch-of-olfa

# Option 1: put the Firebase service account JSON in this file:
# firebase-service-account.json

# Option 2: or point to the service account file with an absolute path:
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\firebase-service-account.json

# Option 3: or paste the whole service account JSON in one line:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"touch-of-olfa"}
